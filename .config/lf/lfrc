cmd broot ${{
    if [ "$lf_user_broot_opt" = "norm" ]; then
        path="$(broot)"
    elif [ "$lf_user_broot_opt" = "whale" ]; then
        path="$(broot -w)"
    else
        lf -remote "send $id echo unknown broot opt '$lf_user_broot_opt'"
        exit 0
    fi

    [ -z "$path" ] && exit 0
    IFS=" "
    path_escaped="${path@Q}"
    path_escaped="${path_escaped// /\\ }"

    if [ -d "$path" ]; then
        bash <(printf "lf -remote \"send $id cd \"%s" "$path_escaped")
    elif [ -e "$path" ]; then
        bash <(printf "lf -remote \"send $id select \"%s" "$path_escaped")
    else
        lf -remote "send $id echo cannot select '$path'"
    fi
}}

