cmd bulk-rename ${{

    run_dir="${XDG_RUNTIME_DIR:-/run/user/0}"

    old="$(mktemp "$run_dir/lf_rename_old_XXXXX")"
    new="$(mktemp "$run_dir/lf_rename_new_XXXXX")"

    if [ -n "$fx" ]; then
        fx="$(basename -a $fx)"
    else
        lf -remote "send $id echo Rename failed, 'fx' is empty."
        return
    fi

    printf '%s\n' "$fx" >"$old"
    printf '%s\n' "$fx" >"$new"

    if [ "$VISUAL" == "nvim" ]; then
        $VISUAL -c "set filetype=text" "$run_dir/$(basename -- "$new")"
    else
        $VISUAL "$new"
    fi

    if [ "$(wc -l < "$new")" -ne "$(wc -l < "$old")" ]; then
        lf -remote "send $id echo Rename failed, number of file names mismatch."
       exit
    fi

    paste "$old" "$new" | while IFS= read -r names; do
        src="$(printf '%s' "$names" | cut -f1)"
        dst="$(printf '%s' "$names" | cut -f2)"
        if [ "$src" = "$dst" ] || [ -e "$dst" ]; then
            continue
        fi
        mv -- "$src" "$dst"
    done
    rm -- "$old" "$new"
    lf -remote "send $id unselect"
}}

