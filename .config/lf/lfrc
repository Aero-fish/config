# ! --------- Options ----------
# Quit server when there are no clients left connected
# Leave it alive for file copying
set autoquit false

# Preview
set previewer '~/.config/lf/lf_kitty_preview_bwrap'
set cleaner '~/.config/lf/lf_kitty_clean'

set dirfirst true
set drawbox true

# Re-name copy/cut file, if name already exist
# %f=file name, %b=base name, %e=extension (including the dot), %n=number of duplicates
set dupfilefmt '%b (%n)%e'

# '*' to match any sequence, '?' to match any character
# '[...]' or '[^...]' to match character sets or ranges
set globsearch false

# Show hidden file on start

# Pattern for hidden file. Can use glob pattern. ':' as separator
set hiddenfiles '.*:lost+found'

# Save command history
set history false

set icons true

# Default empty
set ifs "\n"

set ignorecase true
set smartcase true
set incsearch true
set incfilter true

# Info on the side. 'size:time:atime:ctime', default empty
set info size

set mouse true

# List of attributes that are preserved when copying files
# 'mode:timestamps', default 'mode'
set preserve "mode:timestamps"

# Ratio between panels
set ratios 1:1

set scrolloff 5

set shell 'bash'
set shellopts '-eu'

set tabstop 4

set rulerfmt "%a  |%p  |\033[7;31m %m \033[0m  |\033[7;33m %c \033[0m  |\033[7;35m %s \033[0m  |\033[7;34m %f \033[0m |%d |%i/%t"

# --------- User options ---------
set user_paste_opt ''
set user_broot_opt ''
set user_fzf_opt ''

# --------- Override builtin CMD ---------
cmd open ${{
    if [ "${f##*.}" == "html" ]; then
        (setsid librewolf "$f" &)

    else
        file_type="$(file -Lb --mime-type "$f")"

        if [[ "$file_type" == text/* ]] || [[ "$file_type" == "inode/x-empty" ]]; then
            $VISUAL "$f"

        else
            opener="$(gio mime "$file_type" | head -n1)"
            if [[ "$opener" == "No default applications"* ]]; then
                lf -remote "send $id echo No default program to open the file"

            else
                opener="$(echo "$opener" | sed -E 's/.*:\s*(.*)$/\1/')"
                if [ "$opener" == "nvim.desktop" ]; then
                    $VISUAL "$f"

                else
                    (setsid gio open "$f" >/dev/null 2>&1 </dev/null)
                fi
            fi

        fi
    fi
}}

