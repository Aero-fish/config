    cmd="rg --follow --no-ignore --column --line-number --no-heading --color=always --smart-case --field-match-separator='\x7F:'"
    # Preview takes too much space, not able to show full path
    f="$(
        fzf --ansi --disabled --layout=reverse --header="Search in files" --delimiter='\x7F:' \
            --bind="start:reload([ -n {q} ] && $cmd -- {q} || true)" \
            --bind="change:reload([ -n {q} ] && $cmd -- {q} || true)" \
            --bind="enter:become(printf '%s' {1})"
        )"
        # --bind='enter:become(lf -remote "send $id select \"$(printf "%s" {1} | sed '\''s/\\/\\\\/g;s/"/\\"/g'\'')\"")')"
        # --preview='~/.config/lf/lf_kitty_clean; ~/.config/lf/lf_kitty_preview_bwrap {1} "$FZF_PREVIEW_COLUMNS" "$FZF_PREVIEW_LINES" "$FZF_PREVIEW_LEFT" "$FZF_PREVIEW_TOP"'
    f_escaped="${f@Q}"
    f_escaped="${f_escaped// /\\ }"
    f_escaped="${f_escaped//;/\\;}"
    lf -remote "send $id select $f_escaped"
}}

