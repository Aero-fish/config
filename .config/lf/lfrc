cmd set_permission &{{
    readarray -t arr <<<"$fx"
    for f in "${arr[@]}"; do
        real_path="$(readlink -f "$f")"
        [ ! -e "$real_path" ] && continue
        find "$real_path" -type f -exec /usr/bin/chmod 600 {} \;
        find "$real_path" -type d -exec /usr/bin/chmod 700 {} \;
    done
    lf -remote "send reload"
}}

