esac

count=0
total_count="\${#files[@]}"
overwrite_policy=""
for file in "\${files[@]}"; do
    count=\$((count+1))
    if [ -e "\$file" ]; then
        name="\$(basename -- "\$file")"
        dest=${PWD@Q}/"\${name}.zip"

        if [ -e "\$dest" ]; then
            while [ "\${overwrite_policy}" != "v" ] && [ "\${overwrite_policy}" != "k" ]; do
                read -n 1 -p "'\$dest' already exist. Do you want to [o]verwrite, [s]kip, o[v]erwirte all, or s[k]ip all? " overwrite_policy
                echo

                case "\$overwrite_policy" in
                    [ovsk] ) break;;
                    * ) echo "Unknown option '\$overwrite_policy'";;
                esac
            done

            case "\$overwrite_policy" in
                [ov] ) rm -r "\$dest";;
                [sk] ) continue;;
                * ) echo "Unknown option '\$overwrite_policy'";;
            esac
        fi

        echo "Compressing '\$file'...(\${count}/\${total_count})"
        (cd "\$(dirname -- "\$file")"; zip -r "\$dest" "\$(basename -- "\$file")")

        [ "\$del_file" == "y" ] && [ -s "\${name}.zip" ] && rm -rf "\$file"
    else
        echo "'\$file' does not exist."
    fi
done

notify-send "lf: Archive to individual zip completed "${PWD@Q}
lf -remote "send reload"
read -n 1 -s -p "Press any key to exit..."
rm -- "\$0"
EOF
