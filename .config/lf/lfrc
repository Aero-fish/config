cmd paste ${{
    check_available_space() {
        local -n source_file=$1
        local -n dest_path=$2

        [ "${#source_file[@]}" -eq 0 ] && return

        files_size="$(du -cs --apparent-size --block-size=1K "${source_file[@]}" | tail -1 | awk '{print $1}')"

        free_space="$(df -k "$dest_path" | tail -1 | awk '{print $4}')"
        if [ "$files_size" -gt "$free_space" ]; then
            need_free_space="$((files_size - free_space))"
            need_free_space="$(numfmt --to=iec-i --from=iec-i --suffix=B --format="%9.2f" "${need_free_space}Ki")"
            lf -remote "send $id echo Insufficient free space, need $need_free_space more"
            notify-send "Insufficient free space, need $need_free_space more"
            exit 0
        fi
    }

    ## Exit if nothing is selected
    if [ ! -f "$HOME/.local/share/lf/files" ] ||
        [ "$(cat "$HOME/.local/share/lf/files" | wc -l)" -le 1 ]; then
        lf -remote "send $id echo Nothing to paste"
        exit 0
    fi

    ACTION="$(head -n1 "$HOME/.local/share/lf/files")"
    RUN_DIR="${XDG_RUNTIME_DIR:-/run/user/0}"
    mkdir -p "$RUN_DIR/lf_progress"
    DEST="$PWD"

    ## Read selection into an array, and split them into rsync, mv and duplicate actions
    selected_paths_arr=()
    readarray -t selected_paths_arr < <(sed '1d' "$HOME/.local/share/lf/files")

    rsync_cmd="rsync -ah --no-inc-recursive --info=progress2 --exclude 'lost+found/'"
    mv_cmd="mv"
    rm_empty_dir_cmd=""

    rsync_arr=()
    mv_arr=()
    dup_arr=()

    ## Put each selected paths into 'rsync', 'mv' or 'duplicate'.
    ## Set arguments of the commands based on copy or move.
    if [ "$ACTION" = "move" ]; then
        # For move, if source and destination are on the same device, use mv, else rsync.
        path_is_dir_arr=()
        for path in "${selected_paths_arr[@]}"; do
            if [ "$(stat -c "%d" "$path")" = "$(stat -c "%d" "$DEST")" ]; then
                mv_arr+=("$path")

            else
                rsync_arr+=("$path")

            fi

            if [ -d "$path" ]; then
                path_is_dir_arr+=("$path")
            fi
        done

        rsync_cmd="$rsync_cmd --remove-source-files"

        # Remove empty dir at source after mv and rsync are completed.
        if [ "${#path_is_dir_arr[@]}" -ne 0 ]; then
            rm_empty_dir_cmd="find $(printf '%s ' "${path_is_dir_arr[@]@Q}")-type d -empty -delete"
        fi

        unset path_is_dir_arr

        # Only check rsync usage. mv does not occupy space as the are on the same device.
        check_available_space rsync_arr DEST

    elif [ "$ACTION" = "copy" ]; then
        check_available_space selected_paths_arr DEST

        # Determine whether to copy or duplicate
        for path in "${selected_paths_arr[@]}"; do
            if [ "$(dirname -- "$path")" = "$DEST" ]; then
                dup_arr+=("$path")
            else
                rsync_arr+=("$path")
            fi
        done

    else
        lf -remote "send $id echo Unknown action '$ACTION'"
        exit 0

    fi

    # Check existing file
    paths_to_be_checked=("${mv_arr[@]}" "${rsync_arr[@]}")
    filename_already_exist=()
    for path in "${paths_to_be_checked[@]}"; do
        if [ -e "$DEST/$(basename -- "$path")" ]; then
            filename_already_exist+=("$path")
        fi
    done

    if [ "${#filename_already_exist[@]}" -ne 0 ]; then
        echo "----- File name already exist -----"
        # Trim down to max 50 paths
        if [ "${#filename_already_exist[@]}" -gt 50 ]; then
            filename_already_exist="${filename_already_exist[@]:0:49}"
            filename_already_exist+=("...more...")
        fi
        printf '%s\n' "${filename_already_exist[@]}"
        echo "----------"

        echo -e "File name(s) exists in dest, going to \e[31m$lf_user_paste_opt\e[0m"
        read -n 1 -r -p "Do you want to continue? [y/n] " res
        echo
        if [ "$res" != "y" ]; then
            echo -e "Cancelled\n"
            exit 0
        fi
    fi

    # Create the temp file after all interactions with the user is completed.
    SH_FILE="$(mktemp "$RUN_DIR/lf_progress/${ACTION}_XXXXX.sh")"

    if [ "$lf_user_paste_opt" = "skip" ]; then
        rsync_cmd="$rsync_cmd --ignore-existing --"
        mv_cmd="$mv_cmd --no-clobber --"

    elif [ "$lf_user_paste_opt" = "replace" ]; then
        mv_cmd="$mv_cmd --force --"

    elif [ "$lf_user_paste_opt" = "backup" ]; then
        rsync_cmd="$rsync_cmd --backup --"
        mv_cmd="$mv_cmd --force -b --"

    else
        lf -remote "send $id echo Unknown paste option '$lf_user_paste_opt'"
        exit 0
    fi

    ## Start to create the script
    cat <<EOF >"$SH_FILE"
#!/usr/bin/bash
## Paste to ${DEST@Q}

EOF

    if [ "$ACTION" = "move" ]; then
        cat <<EOF >>"$SH_FILE"
rm -f ~/.local/share/lf/file
lf -remote 'send clear'

EOF
    fi

    ## mv does not work if the destination dir is not empty, need to move file one by one
    ## If destination dir exit, move file one by one.
    ## Otherwise, if source is a file or the destination dir does not exist, mv directly.
    if [ "${#mv_arr[@]}" -ne 0 ]; then
        mv_simple_arr=()
        echo "echo $mv_cmd ${mv_arr[@]@Q} ${DEST@Q}" >>"$SH_FILE"

        for path in "${mv_arr[@]}"; do

            dir_basename="$(basename -- "$path")"

            if [ ! -d "$path" ] || [ ! -d "$DEST/$dir_basename" ]; then
                # Store in an array and move all together using one 'mv'
                mv_simple_arr+=("$path")

            else

                ## mkdir -p all leaf directories
                # Only works on POSIX compliant file system like ext4
                # echo "(cd ${f@Q}; find -type d -links 2 -exec mkdir -p ${dest@Q}/${dir_basename@Q}/{} \;)" >>"$SH_FILE"

                ## Move file one by one
                cat <<EOF >>"$SH_FILE"
mkdir -p ${DEST@Q}/${dir_basename@Q}

arr=()
while read -d \$'\\n' directory; do
    if [ -n "\$last" ] && [[ ! "\$directory" == "\$last"* ]]; then
        arr+=("\$last")
    fi
    last="\$directory"
done < <(find ${path@Q} -mindepth 1 -type d -printf '%P/\\n' | sort)
arr+=("\$last")
printf "%s\\0" "\${arr[@]}" | xargs --no-run-if-empty -0  -I {} mkdir -p ${DEST@Q}/${dir_basename@Q}/{}

error_code="\$?"
if [ "\$error_code" -ne 0 ]; then
    notify-send "lf: $ACTION failed. (mkdir)"
    pw-play "$HOME/.config/my-config/notification_tones/Overheat.wav"
    lf -remote "send reload"
    exit 1
fi

(cd ${path@Q}; fd --unrestricted -tf -tl --exec $mv_cmd {} ${DEST@Q}/${dir_basename@Q}/{})
error_code="\$?"
if [ "\$error_code" -ne 0 ]; then
    notify-send "lf: $ACTION failed.Add rsync to the script (move one by one)"
    pw-play "$HOME/.config/my-config/notification_tones/Overheat.wav"
    lf -remote "send reload"
fi

EOF
            fi
        done

        if [ "${#mv_simple_arr[@]}" -ne 0 ]; then
            cat <<EOF >>"$SH_FILE"
$mv_cmd ${mv_simple_arr[@]@Q} ${DEST@Q}
error_code="\$?"
if [ "\$error_code" -ne 0 ]; then
    notify-send "lf: $ACTION failed. (move simple)"
    pw-play "$HOME/.config/my-config/notification_tones/Overheat.wav"
    lf -remote "send reload"
    exit 1
fi

EOF
        fi
    fi

    ## Add rsync to the script
    if [ "${#rsync_arr[@]}" -ne 0 ]; then
        echo "$rsync_cmd ${rsync_arr[@]@Q} ${DEST@Q}" >>"$SH_FILE"
    fi

    ## Clean up empty source dir. This command is empty for copy.
    [ -n "$rm_empty_dir_cmd" ] && echo "$rm_empty_dir_cmd" >>"$SH_FILE"

    ## Duplicate files with index
    if [ "${#dup_arr[@]}" -ne 0 ]; then
        count=1
        total="${#dup_arr[@]}"
        for path in "${dup_arr[@]}"; do
            # Find free index to append to the duplicate file, up to 100
            for i in {1..100}; do
                dup_name="${path}.~${i}~"
                [ -e "$dup_name" ] && continue
                break
            done

            # In the worst case, rely on cp's backup function to continue index
            # E.g., for index over 100, file.txt.~100~.~1~
            echo "echo cp '$path' '$dup_name' [$count/$total]" >>"$SH_FILE"
            echo "cp -r --backup=t ${path@Q} ${dup_name@Q}" >>"$SH_FILE"
            count="$((count + 1))"
        done
    fi

    cat <<EOF >>"$SH_FILE"
notify-send "lf: $ACTION completed"
lf -remote "send reload"
rm -- "\$0"
EOF
    chmod 700 "$SH_FILE"
    tmux new-session -d -s "$(basename "$SH_FILE")" -- bash "$SH_FILE"
    lf -remote "send $id echo Pasting ${#selected_paths_arr[@]} file(s) - $ACTION"
}}

