    fi

    if [ -z "$file_name" ]; then
        echo "Empty file name"
        exit 0
    fi
    dest="${PWD}/${file_name}.tar.zst"

    # Check if file of same name exists
    if [ -e "$dest" ]; then
    read -n 1 -r -p "'$dest' already exists, overwrite? [y/n] " res
        echo
