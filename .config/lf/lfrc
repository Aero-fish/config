                printf "%s\n%s\n" "$common_dir" "$current_file_dir" |
                sed -e 'N;s/^\(.*\).*\n\1.*$/\1/'
            )"
        fi

        if [ "$common_dir" = "/" ]; then
            break
        fi
    done

    # Add tailing slash
    if [ "$common_dir" != "/" ]; then
        prefix="${common_dir}/"
    else
        prefix="$common_dir"
    fi

    arr_trim=("${arr[@]#"$prefix"}")

    tar_cmd=("tar" "--owner=0" "--group=0" "-C" "${common_dir@Q}" "-cpf" "-")
