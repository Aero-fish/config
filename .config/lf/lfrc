cmd delete ${{
    readarray -t arr <<<"$fx"
    [ "${#arr[@]}" -eq 0 ] && {
        lf -remote "send $id echo Nothing to delete"
        exit 0
    }

    if [ "${#arr[@]}" -gt 12 ]; then
        echo -n "Delete all ${#arr[@]} files? [y/n]"
    else
        echo "Delete the following ${#arr[@]} file(s)?"
        printf '%s\n' "${arr[@]}"
        echo -n "[y/n]"
    fi
    read -n 1 -r res
    echo -e "\n"
    if [ "$res" != "y" ]; then
        echo -e "Cancelled\n"
        exit 0
    fi

    run_dir="${XDG_RUNTIME_DIR:-/run/user/0}"
    mkdir -p "$run_dir/lf_progress"
    SH_FILE="$(mktemp "$run_dir/lf_progress/rm_XXXXX.sh")"

    rm_arr=()
    trash_arr=()
    for f in "${arr[@]}"; do
        if [ ! -f "$f" ] && [ ! -d "$f" ]; then
            rm_arr+=("$f")

        elif [ "$(basename -- "$f")" == ".Trash-$(id -u)" ]; then
            rm_arr+=("$f")

        elif [ "$(du -s --apparent-size --block-size=1M "$f" | awk '{print $1}')" -gt 50 ]; then
            rm_arr+=("$f")

        else
            trash_arr+=("$f")

        fi
    done

    echo "#$PWD" >"$SH_FILE"
    [ "${#rm_arr[@]}" -ne 0 ] && {
        echo "rm:"
        printf '%s\n' "${rm_arr[@]}"
        echo

        echo "#rm:" >>"$SH_FILE"
        printf '#%s\n' "${rm_arr[@]}" >>"$SH_FILE"
        echo >>"$SH_FILE"

    }

    [ "${#trash_arr[@]}" -ne 0 ] && {
        echo "trash-put:"
        printf '%s\n' "${trash_arr[@]}"

        echo "#trash-put:" >>"$SH_FILE"
        printf '#%s\n' "${trash_arr[@]}" >>"$SH_FILE"
        echo >>"$SH_FILE"
    }

    [ "${#trash_arr[@]}" -ne 0 ] && {
        echo "trash-put --force --verbose ${trash_arr[@]@Q} 2>&1 | rg '^trash-put: trying' | pv -l -N 'trash-put' -s '${#trash_arr[@]}' >/dev/null" >>"$SH_FILE"
    }

    [ "${#rm_arr[@]}" -ne 0 ] && {

        echo "rm -rvf ${rm_arr[@]@Q} | pv -l -N 'rm' -s '$(du -a "${rm_arr[@]}" | wc -l)' >/dev/null" >>"$SH_FILE"
    }

    cat <<EOF >>"$SH_FILE"
lf -remote "send unselect"
lf -remote "send reload"
notify-send "lf: rm completed"
rm -- "\$0"
EOF
    chmod 700 "$SH_FILE"
    tmux new-session -d -s "$(basename "$SH_FILE")" -- bash "$SH_FILE"
    lf -remote "send $id echo Remove ${#arr[@]} file(s)"

}}
