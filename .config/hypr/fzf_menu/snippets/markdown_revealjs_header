## Math equations flush left
# classoption:
#     - fleqn

header-includes: |
    <style>
    * {
        background-size: contain;
        background-repeat: no-repeat;
        background-position: center;
    }
    .title {
        font-size: 3em !important;
    }
    .subtitle {
        font-style: italic !important;
        text-decoration: underline;
    }
    .slide {
        /* Additional offset on top */
        margin-top: 8%;
        text-align: left;
    }
    h1,h2,h3,h4,h5,h6 {
        text-align: center;
    }
    figure {
        font-style: italic !important;
        text-align: center;
    }
    figcaption {
        font-style: italic;
        text-align: center;
        color: grey;
    }
    code {
        background-color: white;
        white-space: pre-wrap;
    }
    /* Also '.title' '.quarto-title-author-name' '.date', need to add '!important' */
    </style>
