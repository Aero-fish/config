#!/usr/bin/sh
[ ! -d "$XDG_RUNTIME_DIR/lf_progress" ] && exit 0

selected="$(
fd -tx --glob -- "*.sh" "$XDG_RUNTIME_DIR/lf_progress" |
    fzf -i --multi --exact --reverse --prompt="Kill operation:" \
        --delimiter / --with-nth -1 --preview "less {}"
    )"


while read -r f; do
     pkill -15 -f "^(/usr/bin|/bin|)bash $f" >/dev/null 2>&1 || true
     rm "$f"
done <<< "$selected"

