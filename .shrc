#
# ${HOME}/.shrc
#

#  ====================
# Environment variables
# ====================

# ---------- set time zone ----------
if [ ! -f "$HOME/.config/tz" ]; then
    echo "## Use tzselect to find the name of time zone" >"$HOME/.config/tz"
    echo "export TZ='Pacific/Auckland'" >>"$HOME/.config/tz"
fi
source "$HOME/.config/tz"

# ---------- Var for this script ----------
this_shell="$(ps -hp $$ | awk '{print $5}' | sed -E -e 's:^(.*/)?-*::')"

# ---------- Settings ----------
export EDITOR=nvim
export VISUAL=nvim
export PAGER=less
export GPG_TTY="$(tty)"

# Perl and CPAN
export PERL5LIB="$HOME/.perl5/lib/perl5${PERL5LIB:+:${PERL5LIB}}"
export PERL_LOCAL_LIB_ROOT="$HOME/.perl5${PERL_LOCAL_LIB_ROOT:+:$PERL_LOCAL_LIB_ROOT}"
export PERL_MB_OPT="--install_base '$HOME/.perl5'"
export PERL_MM_OPT="INSTALL_BASE='$HOME/.perl5'"

# nodejs
# export PATH="$HOME/.node_modules/bin:$PATH"
export npm_config_prefix="$HOME/.node_modules"

# WINE
export WINEPREFIX="$HOME/.wine/default"

# Add my scripts to PATH
# export PATH="$HOME/.cargo/bin:$PATH"
export PATH="$HOME/.local/bin:$PATH"

# ---------- `less` pager style ----------
export LESS="--clear-screen --ignore-case --no-lessopen --LONG-PROMPT --RAW-CONTROL-CHARS --HILITE-UNREAD --tabs=4 --no-init --incsearch --mouse --wordwrap"

## No search history for `less`
export LESSHISTFILE="/dev/null"

# Scheme 1
#export LESS_TERMCAP_mb=$'\E[1;31m'     # begin blink
#export LESS_TERMCAP_md=$'\E[1;36m'     # begin bold
#export LESS_TERMCAP_me=$'\E[0m'        # reset bold/blink
#export LESS_TERMCAP_so=$'\E[01;44;33m' # begin reverse video
#export LESS_TERMCAP_se=$'\E[0m'        # reset reverse video
#export LESS_TERMCAP_us=$'\E[1;32m'     # begin underline
#export LESS_TERMCAP_ue=$'\E[0m'        # reset underline

# Scheme 2
export LESS_TERMCAP_mb=$'\E[1;31m'
export LESS_TERMCAP_md=$'\E[1;31m'
export LESS_TERMCAP_me=$'\E[0m'
export LESS_TERMCAP_se=$'\E[0m'
#export LESS_TERMCAP_so=$'\E[1;44;33m'  # Ugly status line highlight
export LESS_TERMCAP_ue=$'\E[0m'
export LESS_TERMCAP_us=$'\E[1;32m'

# ---------- hyprland ----------
if [ -x /usr/bin/Hyprland ]; then
    alias hyprland-via-uwsm="uwsm start hyprland-uwsm.desktop"
fi

