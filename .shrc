alias fastping="ping -c 100 -s.2"

alias nv="nvim"
alias v='$EDITOR'
alias vv='$EDITOR_GUI'

alias incognito=' unset HISTFILE'

_get_basename() {
    fullname="${1##*/}"
    echo "${fullname%.*}"
}

# ---------- Rust replacement ----------
if [ -f /usr/bin/bat ]; then
    alias cat="bat"
    if [ "$TERM" = "linux" ]; then
        export BAT_CONFIG_PATH="$HOME/.config/bat/config.tty"
    fi
fi

# ---------- Backup ----------
mirror() {
    [ ! $# -eq 2 ] && {
        echo -e "Mirror source to destination.\nUsage: mirror source_path destination_path"
        return
    }

    scr_path="$1"
    dest_path="$2"

    ## Check destination path, never write to 'Bak' folder
    if echo "$dest_path" | grep -qEi -e ".*/(back|backup|.backup)/*"; then
        echo -n "The destination is '$dest_path', type YES to continue:"
        read -r continue_mirror
        [ ! "$continue_mirror" = "YES" ] && return
    fi
    if [ ! -e "$scr_path" ]; then
        echo "$scr_path does not exist"
        return
    fi
    if [ ! -e "$dest_path" ]; then
        echo "$dest_path does not exist"
        return
    fi

    rsync -ah --delete --no-inc-recursive --info=progress2 --exclude "lost+found/" "$scr_path" "$dest_path"
}

mirror-bak() {
    echo "mirror '/run/media/$(id -u -n)/T5_EVO/' to '/run/media/$(id -u -n)/Bak'"
    mirror "/run/media/$(id -u -n)/T5_EVO/" "/run/media/$(id -u -n)/Bak"
}
# ---------- ls ----------
glob_ignore_pattern="*cache|.cargo|.git|.gnupg|.gphoto|.ipython|.jupyter|.lastpass|.npm|.nv|.password-store|.perl5|.pki|.svn|.texlive|.vscode-oss|.wine|__pycache__|go|lost+found|mozilla*|librewolf*|node_modules|thunderbird"

if [ -f /usr/bin/eza ]; then
    # '--classify' indicates type at the end (*=exe, /=dir, |=FIFO, @=symbolic
    alias ls="eza --colour=automatic --classify --group-directories-first"
    alias ll="eza --colour=automatic --classify --long --group-directories-first --binary --group --links --modified"                   # long list
    alias la="eza --colour=automatic --classify --long --all --group-directories-first --binary --group --links --modified"             # long list all
    alias ld="eza --colour=automatic --classify --long --all --only-dirs --group-directories-first --binary --group --links --modified" # long list directory
    alias l.="eza --colour=automatic --classify --long --all -d .* --group-directories-first --binary --group --links --modified"       # list hidden

    alias llm="eza --colour=automatic --classify --long --reverse --sort=modified --group-directories-first --binary --group --links --modified" # long list sort by modified date
    alias lls="eza --colour=automatic --classify --long --reverse --sort=size --group-directories-first --binary --group --links --modified"     # long list sort by size

    # shellcheck disable=SC2139
    alias ltree="eza --colour=automatic --classify --tree --level=3 --all --group-directories-first --sort=name --ignore-glob='$glob_ignore_pattern'"

else
    alias ls="ls --color=auto --classify --group-directories-first"
    alias ll="ls --color=auto --classify --group-directories-first --human-readable -l"                  # long list
    alias la="ls --color=auto --classify --group-directories-first --human-readable -l --almost-all"     # long list all
    alias ld="ls --color=auto --human-readable -l --almost-all --directory */ .*/"                       # long list directory
    alias l.="ls --color=auto --human-readable --group-directories-first -l --almost-all --directory .*" # list hidden

    alias llm="ls --color=auto --classify --group-directories-first --human-readable -l --sort=time" # long list sort by modified date
    alias lls="ls --color=auto --classify --group-directories-first --human-readable -l --sort=size" # long list sort by size

    # shellcheck disable=SC2139
    alias ltree="tree -L 3 -F --dirsfirst --sort=name --ignore-case -I '$glob_ignore_pattern'" # tree-view
fi
unset ignore_glob_pattern

