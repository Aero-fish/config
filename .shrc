# ---------- Permission fix ---------
permission-fix() {
    if [ -d "$1" ]; then
        find "$1" -type f -exec /usr/bin/chmod 600 {} \; && find "$1" -type d -exec /usr/bin/chmod 700 {} \;
    else
        echo "Change permission of all files/directories to 600 and 700"
        echo "Usage: permission-fix-tight <directory>"
        echo "E.g., permission-fix-tight . , permission-fix-tight ~/dir"
    fi
}

# ---------- ffmpeg ----------
alias ffmpeg-ls-encoders="ffmpeg -encoders"

ffmpeg-show-encoders-help() {
    ffmpeg -h encoder="$1"
}

ffmpeg-ls-video-streams() {
    ffprobe "$1" 2>&1 >/dev/null | grep Stream
}

ffmpeg-stream-extract() {
    ffmpeg -i "$1" -map 0:"$2" -c copy "$3"
}

mkv-stream-extract() {
    mkvextract "$1" tracks "$2:$3"
}

ffmpeg-audio-downmix-to-aac() {
    ffmpeg -i "$1" -map 0:v:0 -map 0:a:0 -map 0:s -af "pan=stereo|FL=0.5*FC+0.707*FL+0.707*BL+0.5*LFE|FR=0.5*FC+0.707*FR+0.707*BR+0.5*LFE" -c copy -c:a aac -b:a 256K "$(_get_basename "$1").new.mkv"
    echo "Output to '$(_get_basename "$1").new.mkv'."
}

ffmpeg-audio-convert-to-ac3() {
    ffmpeg -i "$1" -map 0 -c copy -c:a ac3 -b:a 640K "$(_get_basename "$1").new.mkv"
    echo "Output to '$(_get_basename "$1").new.mkv'."
}

ffmpeg-compress-video() {
    ## Ignore metadata
    ffmpeg -i "$1" -c:v libx265 -x265-params crf=23 -c:a copy -c:s copy "$(_get_basename "$1").new.mkv"

    ## Also copy metadata
    #ffmpeg -i "$1" -map 0 -c:v libx265 -x265-params crf=23 -c:a copy -c:s copy "${basename}.new.mkv"

    echo "Output to '$(_get_basename "$1").new.mkv'."
}

# ---------- archiver ----------
archive-to-single-tar-zstd() {
    # Guess the common dir
    common_dir=""
    for f in "${@}"; do
        if [ -z "$common_dir" ]; then
            common_dir="$(dirname -- "$f")"
        else
            current_file_dir="$(dirname -- "$f")"
            common_dir="$(
                printf "%s\n%s\n" "$common_dir" "$current_file_dir" |
                    sed -e 'N;s/^\(.*\).*\n\1.*$/\1/'
            )"
        fi

        if [ "$common_dir" = "/" ]; then
            break
        fi
    done
    # Add tailing slash
    if [ "$common_dir" != "/" ]; then
        prefix="${common_dir}/"
    else
        prefix="$common_dir"
    fi

    arr_trim=("${@#"$prefix"}")

    local tar_cmd=("tar" "--owner=0" "--group=0" "-C" "$common_dir" "-cpf" "-")
    local du_cmd=("du" "-cbs")

    tar_cmd+=("${arr_trim[@]}")
    du_cmd+=("${@}")

    if [ "$#" -eq 1 ]; then
        file_name="$(basename -- "$1")"
    else
        printf "Enter output file name without extension: "
        read -r file_name
    fi

    if [ -z "$file_name" ]; then
        echo "Empty file name"
        return
    fi
    dest="${PWD}/${file_name}.tar.zst"

    # Check if file of same name exists
    if [ -e "$dest" ]; then
        read -n 1 -r -p "'$dest' already exists, overwrite? [y/n] " res
        echo
        case "$res" in
        [Yy]) rm -r "$dest" ;;
        *) exit 0 ;;
        esac
    fi

    "${tar_cmd[@]}" | pv -s "$("${du_cmd[@]}" | tail -1 |
        awk '{print $1}')" |
        zstdmt >"$dest"

    notify-send "shell: Archive competed $dest"
    lf -remote "send reload"

}

# ---------- archive extractor ----------
## usage: ex <file>
ex() {
    if [ "$#" -ne 1 ]; then
        echo "usage: ex <file>"
    elif [ -f "$1" ]; then
        case $1 in
        *.tar.bz2) pv "$1" | tar -xjpf - ;;
        *.tar.gz) pv "$1" | tar -xzpf - ;;
        *.tar.xz) pv "$1" | tar -I pixz -xpf - ;;
        *.tar.zst) pv "$1" | tar --zstd -xpf - ;;
        *.bz2) bunzip2 -kc "$1" >./"$(basename -- "$1" | sed -E 's:\\.bz2$::')" ;;
        *.rar) unrar x "$1" ;;
        *.gz) gunzip -kc "$1" >./"$(basename -- "$1" | sed -E 's:\\.gz$::')" ;;
        *.tar) pv "$1" | tar -xpf - ;;
        *.tbz2) pv "$1" | tar -xjpf - ;;
        *.tgz) pv "$1" | tar -xzpf - ;;
        *.zip) unzip "$1" ;;
        *.Z) uncompress "$1" ;;
        *.deb) ar -x "$1" ;;
        *.7z) 7z x "$1" ;;
        *.iso) 7z x "$1" ;;
        *.rpm) rpmextract.sh "$1" ;;
        *.AppImage)
            if [ ! -x "$1" ]; then
                if [ ! -w "$1" ]; then
                    echo "'$1' is not executable, and cannot chmod"
                    return
                fi

                if [ -O "$1" ]; then
                    chmod u+x "$1"
                elif [ -G "$1" ]; then
                    chmod g+x "$1"
                else
                    chmod o+x "$1"
                fi
            fi
            work_path="$(dirname -- "$(realpath --no-symlinks -- "$1")")"
            file_name="$(basename -- "$1")"
            echo "Extracting '$1'"
            bwrap \
                --unshare-user \
                --unshare-ipc \
                --unshare-pid \
                --unshare-uts \
                --unshare-cgroup-try \
                \
                --disable-userns \
                --hostname my-pc \
                --proc /proc \
                --cap-drop ALL \
                --new-session \
                --die-with-parent \
                --seccomp 9 \
                \
                --ro-bind-try "/usr" "/usr" \
                --symlink "/usr/bin" "/bin" \
                --symlink "/usr/bin" "/sbin" \
                --symlink "/usr/lib" "/lib" \
                --symlink "/usr/lib" "/lib64" \
                --bind-try "$work_path" "$work_path" \
                "$work_path/$file_name" --appimage-extract \
                9</usr/local/share/seccomp-filter/default_seccomp_filter.bpf >/dev/null
            ;;
        *) echo "'$1' cannot be extracted via ex()" ;;
        esac
    else
        echo "'$1' is not a valid file"
    fi
}

