# ---------- youtube-dl ----------
_ytdl() {
    local COOKIE_PATH="$(find "$HOME/Documents/youtube-log/mozilla-ytdl" -type d -regex '.*default-release' | head -n 1)"
    echo -e "\e[31mDownloading to Desktop\e[0m"
    /usr/local/bin/generic_bwrap \
        --bind-try "$COOKIE_PATH" "$HOME/.cache/yt" \
        --ro-bind-try "$HOME"/misc/repo/ffmpeg-yt-dlp "$HOME"/misc/repo/ffmpeg-yt-dlp \
        --ro-bind-try "$HOME"/misc/repo/yt-dlp "$HOME"/misc/repo/yt-dlp \
        "$HOME"/misc/repo/yt-dlp/bin/yt-dlp \
        --ffmpeg-location "$HOME/misc/repo/ffmpeg-yt-dlp" \
        --js-runtimes node \
        --cookies-from-browser firefox:"$HOME/.cache/yt" \
        "$@"
}

yt-info() {
    _ytdl --print filename \
        --output "https://www.youtube.com/channel/%(channel_id)s/videos,%(channel)s" \
        "$1"
}

ytdl() {
    _ytdl --merge-output-format mp4 \
        --continue -N 3 \
        --retries "infinite" \
        --all-subs --embed-subs --add-metadata --embed-thumbnail \
        --no-restrict-filenames --windows-filenames \
        --output "$HOME/Desktop/%(upload_date).8s %(title).40s.%(ext)s" \
        "$1"
}

ytdl_long_name() {
    _ytdl --merge-output-format mp4 \
        --continue -N 3 \
        --retries "infinite" \
        --all-subs --embed-subs --add-metadata --embed-thumbnail \
        --no-restrict-filenames --windows-filenames \
        --output "$HOME/Desktop/%(upload_date).8s %(title)s.%(ext)s" \
        "$1"
}

# ---------- number conversion ----------
hex2dec() {
    printf "%d\n" "0x$1"
}
dec2hex() {
    printf "%x\n" "$1"
}

# ---------- fzf ----------
# fzf, fuzzy search in current dir
# <Ctrl T> fuzzy search files+folders (Can select multiple file)
# <Ctrl R> fuzzy search history
# <Alt C> fuzzy change dir
# COMMAND [DIRECTORY/][FUZZY_PATTERN]**<TAB>
# Use Ctrl+J Ctrl+k to move around the list, and <TAB> to select multiple.
#
# ^music    # prefix-exact-match
# .mp3$     # suffix-exact-match
# 'wild     # exact-match(quoted)
# !fire     # inverse-exact-match
# !.mp3$    # inverse-suffix-exact-match
# E.g., ^core go$ | rb$ | py$
# kill -9 <TAB>
# unset **<TAB>
# export **<TAB>
# unalias **<TAB>
# ssh **<TAB>
# telnet **<TAB>

fd_ignore_pattern=(
    "--exclude" "*.kdb" "--exclude" "*.kdbx" "--exclude" "*.key" "--exclude" "*cache/"
    "--exclude" ".cargo/" "--exclude" ".cert" "--exclude" ".fpm/" "--exclude" ".git/"
    "--exclude" ".gnupg/" "--exclude" ".gphoto/" "--exclude" ".hyprland/" "--exclude"
    ".ipython/" "--exclude" ".jupyter/" "--exclude" ".keepass/" "--exclude"
    ".keepassxc/" "--exclude" ".lastpass/" "--exclude" ".npm/" "--exclude" ".nv"
    "--exclude" ".password-store/" "--exclude" ".perl5/" "--exclude" ".pki/"
    "--exclude" ".snapshots/" "--exclude" ".ssh/" "--exclude" ".svn/" "--exclude"
    ".texlive/" "--exclude" ".vscode-oss/" "--exclude" ".wine/" "--exclude" "Bitwarden/"
    "--exclude" "KeePass/" "--exclude" "KeePassXCrc/" "--exclude" "__pycache__/"
    "--exclude" "containers/" "--exclude" "go/" "--exclude" "keepass/" "--exclude"
    "keepassx/" "--exclude" "keepassxc/" "--exclude" "keyrings/" "--exclude"
    "lost+found" "--exclude" "mozilla*/" "--exclude" "librewolf*/"
    "--exclude" "node_modules/" "--exclude" "rclone/" "--exclude" "thunderbird/"
)

export FZF_DEFAULT_COMMAND="fd --unrestricted --follow --ignore-case ${fd_ignore_pattern[*]}"
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND="$FZF_DEFAULT_COMMAND --type d"
export FZF_DEFAULT_OPTS="$FZF_DEFAULT_OPTS -m --bind ctrl-a:select-all,ctrl-d:deselect-all,ctrl-t:toggle-all"

_fzf_compgen_path() {
    fd --unrestricted --ignore-case --follow "${fd_ignore_pattern[@]}" . "$1"
}

_fzf_compgen_dir() {
    fd --type d --unrestricted --ignore-case --follow "${fd_ignore_pattern[@]}" . "$1"
}

if [ "$this_shell" == "bash" ]; then
    [ -f /usr/share/fzf/key-bindings.bash ] && source /usr/share/fzf/key-bindings.bash
    [ -f /usr/share/fzf/completion.bash ] && source /usr/share/fzf/completion.bash

elif [ "$this_shell" == "zsh" ]; then
    # shellcheck disable=SC1094
    [ -f /usr/share/fzf/completion.zsh ] && source /usr/share/fzf/completion.zsh
    # shellcheck disable=SC1094
    [ -f /usr/share/fzf/key-bindings.zsh ] && source /usr/share/fzf/key-bindings.zsh

fi

unset fd_ignore_pattern

# ---------- z ----------
# `z` for jump, `zi` for interactive jump
if [ -r /usr/bin/zoxide ]; then
    export _ZO_DATA_DIR=${HOME}/.cache/zsh
    eval "$(zoxide init "$this_shell")"
fi

# ---------- nnn ----------
if [ -x /usr/bin/nnn ]; then
    alias N="sudo -E nnn -H"
    alias ncp="cat \${NNN_SEL:-\${XDG_CONFIG_HOME:-\$HOME/.config}/nnn/.selection} | tr '\0' '\n'"

    if [ -f "$HOME/.config/nnn/env" ]; then
        source "$HOME/.config/nnn/env"
    fi

    # cd on quit via ^g, provide function 'n'
    if [ -f /usr/share/nnn/quitcd/quitcd.bash_sh_zsh ]; then
        # shellcheck disable=SC1091
        source /usr/share/nnn/quitcd/quitcd.bash_sh_zsh
    fi
fi

# Sort order, capitalise to reverse
# 'a'pparent disk usage / 'd'isk usage / file 'e'xtension / 'r'everse / 's'ize / 't'ime / 'v'ersion

# ---------- lf ----------
# [ -n "$LF_LEVEL" ] && PS1="$PS1""(lf level: $LF_LEVEL) "
if [ -x /usr/bin/lf ]; then
    # cd on quit
    if [ -f /etc/profile.d/lfcd.sh ]; then
        source /etc/profile.d/lfcd.sh
        alias lf=lfcd
    fi
fi

# ---------- System ----------
## get top process eating memory ##
alias psmem='ps auxf | sort -nr -k 4'
alias psmem10='ps auxf | sort -nr -k 4 | head -10'

## get top process eating cpu ##
alias pscpu='ps auxf | sort -nr -k 3'
alias pscpu10='ps auxf | sort -nr -k 3 | head -10'

# shutdown or reboot
alias ssn="sudo shutdown now"
alias sr="sudo reboot"

# get error messages from journalctl. Use 'jctl -1' for previous boot.
alias jctl="journalctl -p 3 -xb"

# DEC850 router tty access
alias dec850-tty="screen /dev/ttyUSB0 115200"

# Use for ssh if foot is not recognized
alias foot-with-terminfo="foot --term xterm-256color"

alias check-cpu-vulnerabilities="grep -r . /sys/devices/system/cpu/vulnerabilities/"
alias ls-installed-packages="pacman -Qe | cut -d' ' -f1'"
alias watch-cpu-freq="watch -n 1 'cat /proc/cpuinfo | grep \"^[c]pu MHz\"'"

alias clean-zsh-history='\rm -f "$HOME/.cache/zsh"/*'
alias test-terminal-bell="echo -e '\07'"
alias soft-reboot="systemctl soft-reboot"

# Container for building
alias aur-container="podman run -it --rm -v \$HOME/misc/repo:/home/user/aur --userns keep-id -u user localhost/archlinux-aur-build bash"

alias ls-network-connections="ss --tcp --udp --processes"
alias ls-network-port-listening="ss --listening --tcp --udp --processes"
alias ls-network-bandwidth-usage="nethogs -v 4"

ls-dbus() {
    echo "---------- System ----------"
    dbus-send --system --print-reply \
        --dest=org.freedesktop.DBus \
        /org/freedesktop/DBus \
        org.freedesktop.DBus.ListNames
    echo "---------- User ----------"
    dbus-send --print-reply \
        --dest=org.freedesktop.DBus \
        /org/freedesktop/DBus \
        org.freedesktop.DBus.ListNames
}

ls-timer() {
    echo "---------- System ----------"
    systemctl --no-pager list-timers
    echo "---------- User ----------"
    systemctl --no-pager --user list-timers
}

ls-dbus-method() {
    if [ $# -ne 1 ]; then
        echo "E.g., ls-dbus-method org.gnome.NautilusPreviewer"
        return
    fi
    dest="$1"
    addr="/${dest//.//}"
    dbus-send --type=method_call --print-reply \
        --dest="$dest" \
        "$addr" \
        org.freedesktop.DBus.Introspectable.Introspect
}

ls-enabled-services() {
    echo "---------- System ----------"
    systemctl list-unit-files | grep enabled
    echo "---------- User ----------"
    systemctl --user list-unit-files | grep enabled
}

ls-running-services() {
    echo "---------- System ----------"
    systemctl | grep running
    echo "---------- User ----------"
    systemctl --user | grep running
}

ls-fonts() {
    fc-list -v |
        grep -E "^\s*(family:|familylang:|style:|fullname:|file:|postscriptname:|Pattern has)" |
        sed -E "s:Pattern has.*:\n----------:" | sed -E "s:^\s*::"
}

alias ls-kitty-fonts="kitty +list-fonts --psnames"

ls-IOMMU() {
    # shopt -s nullglob
    for g in "/sys/kernel/iommu_groups"/*; do
        echo "IOMMU Group ${g##*/}:"
        for d in "$g/devices"/*; do
            echo
            echo -e "\t$(lspci -nns "${d##*/}")"
        done
        echo "----------"
    done
}

ls-IOMMU-usb() {
    for usb_ctrl in /sys/bus/pci/devices/*/usb*; do
        pci_path="${usb_ctrl%/*}"
        iommu_group=$(readlink "${pci_path}/iommu_group")
        if [ -f "$usb_ctrl/busnum" ]; then
            echo "Bus $(cat "${usb_ctrl}/busnum") --> ${pci_path##*/} (IOMMU group ${iommu_group##*/})"
            lsusb -s "${usb_ctrl#*/usb}":
            echo
        fi
    done
}

refresh-desktop-mime() {
    mkdir -p "${HOME}"/.local/share/mime/packages
    rm -f "${HOME}"/.local/share/applications/wine-extension*.desktop
    rm -f "${HOME}"/.local/share/icons/hicolor/*/*/application-x-wine-extension*
    rm -f "${HOME}"/.local/share/applications/mimeinfo.cache
    rm -f "${HOME}"/.local/share/mime/packages/x-wine*
    rm -f "${HOME}"/.local/share/mime/application/x-wine-extension*
    update-desktop-database "${HOME}"/.local/share/applications
    update-mime-database "${HOME}"/.local/share/mime/
}

# Inhibit from suspension
no-suspend() {
    if pgrep -x sway >/dev/null 2>&1 || pgrep -x Hyprland >/dev/null 2>&1; then
        bash -c 'sleep infinity; echo no-suspension ended'
    elif pgrep -x gnome-shell >/dev/null 2>&1; then
        gnome-session-inhibit --inhibit suspend --inhibit-only
    else
        echo "Unknown DE"
    fi
}

spawn() {
    arg=("$@")
    setsid "${arg[@]}" >/dev/null 2>&1 </dev/null &
}

print-24bit-colours() {
    # width=50  # Width, default terminal width
    # height=1  # Number of lines, default 1
    awk -v term_cols="${width:-$(tput cols || echo 80)}" \
        -v term_lines="${height:-1}" \
        'BEGIN{
        s="/\\";
        total_cols=term_cols*term_lines;
        for (colnum = 0; colnum<total_cols; colnum++) {
            r = 255-(colnum*255/total_cols);
            g = (colnum*510/total_cols);
            b = (colnum*255/total_cols);
            if (g>255) g = 510-g;
            printf "\033[48;2;%d;%d;%dm", r,g,b;
            printf "\033[38;2;%d;%d;%dm", 255-r,255-g,255-b;
            printf "%s\033[0m", substr(s,colnum%2+1,1);
            if (colnum%term_cols==term_cols) printf "\n";
        }
        printf "\n";}'
    unset width height
}

# alias scan-network-printers="lpinfo --include-schemes dnssd -v"
alias scan-network-printers="driverless --std-ipp-uris"
alias scan-bonjour="avahi-browse --all --resolve"
alias get-printer-protocol="/usr/lib/cups/backend/snmp"

lg() {
    export LAZYGIT_NEW_DIR_FILE=~/.cache/lazygit/newdir

    lazygit "$@"

    if [ -f $LAZYGIT_NEW_DIR_FILE ]; then
        cd "$(cat $LAZYGIT_NEW_DIR_FILE)" || true
        rm -f $LAZYGIT_NEW_DIR_FILE >/dev/null
    fi
}

trash() {
    [ $# -eq 0 ] && {
        echo "Trash file/folder under 50MB, otherwise rm it. Usage: trash FILE..."
        return
    }
    for f in "$@"; do
        [ ! -e "$f" ] && continue
        if [ "$(du -s --apparent-size --block-size=1M "$f" | tail -1 | awk '{print $1}')" -gt 50 ]; then
            echo "rm -rf \"$f\""
            rm -rf "$f"
        else
            echo "trash-put --force \"$f\""
            trash-put --force "$f"
        fi
    done
    echo "Done"
}

check-smart() {
    local result
    for d in $(smartctl --scan -d scsi | cut -d' ' -f1); do
        result="$(smartctl -H -d sat "$d" | grep "self-assessment test result:" | sed 's/^[^:]*:\s*//')"
        mode="sat"
        if [ -z "$result" ]; then
            result="$(smartctl -H -d scsi "$d" | grep "SMART Health Status:" | sed 's/^[^:]*:\s*//')"
            mode="scsi"
        fi
        echo "$d: $mode: $result"
    done
}

rank-pacman-mirror() {
    if [ ! -f /etc/pacman.d/mirrorlist.backup ]; then
        echo "Make backup for /etc/pacman.d/mirrorlist"
        sudo install -m 644 /etc/pacman.d/mirrorlist /etc/pacman.d/mirrorlist.backup
    fi

    echo "Ranking servers from NZ and AU"
    printf "%s\n%s" \
        "$(awk "/^## (New Zealand)$/{f=1; next}f==0{next}/^\$/{exit}{print substr(\$0, 1);}" /etc/pacman.d/mirrorlist.backup)" \
        "$(awk "/^## (Australia)$/{f=1; next}f==0{next}/^\$/{exit}{print substr(\$0, 1);}" /etc/pacman.d/mirrorlist.backup)" |
        sed "s/^#Server/Server/" |
        rankmirrors -n 10 - |
        sodu tee /etc/pacman.d/mirrorlist >/dev/null
}

# ---------- MIME ----------
alias get-mime="file -Lb --mime-type "
get-mime-default() {
    gio mime "$(file -Lb --mime-type "$1")"
}

set-mime-default() {
    if [ $# -ne 2 ]; then
        echo "set-default-mime <mimetype> <program_name>.desktop"
        return
    fi
    gio mime "$1" "$2"
}

open() {
    local file_type="$(file -Lb --mime-type "$1")"
    local opener="$(gio mime "$file_type" | head -n1)"
    if [[ "$opener" == "No default applications"* ]]; then
        echo "No default program to open the file"

    else
        opener="$(echo "$opener" | sed -E 's/.*:\s*(.*)$/\1/')"
        echo "opening file '$1' of type '$file_type' with '$opener'"
        (setsid gio open "$1" >/dev/null 2>&1 </dev/null)
    fi
}

# ---------- rclone ----------
alias rclone="rclone --progress"

# shellcheck disable=SC2034
rclone_args="--verbose --links"

# shellcheck disable=SC2034
declare -A rclone_paths=(
    # ["5"]="$HOME/5_RAUTANGI_RD"
    # ["workspace"]="$HOME/workspace"
    # ["documents"]="$HOME/Documents"
    # ["gnucash"]="$HOME/.backup/gnucash"
)

_rclone_ignore_list() {
    local rsync_dir="$1"
    local ignore_config_name=".rclone_ignore"
    local exclude_list=""

    while read ignore_file_path; do
        exclude_list="$exclude_list$(cat "$rsync_dir/$ignore_file_path")\n"
    done < <(find -L "$1" -type f -iname "$ignore_config_name" -printf "%P\n")

    echo "$exclude_list"
}

# Aliases are created in zshrc and bashrc due to different syntax

# ---------- PDFs and images ----------
image-to-pdf() {
    if [ "$#" == 0 ]; then
        echo "Usage: image-to-pdf input-files [output.pdf]"
        return
    fi

    local pdf_name
    pdf_name="pdf_output.pdf" # Default name for the output pdf

    if [ "$#" -gt 1 ]; then
        local last_arg last_arg_lower

        ## zsh only
        # last_arg_lower="$(basename -- "${@[${#}]}" | tr '[:upper:]' '[:lower:]')"

        ## bash only
        # last_arg_lower="$(echo "${@:-1}" | tr '[:upper:]' '[:lower:]')"

        ## Universal
        for f in "$@"; do last_arg="$f"; done
        last_arg_lower="$(echo "$last_arg" | tr '[:upper:]' '[:lower:]')"

        if [[ "$last_arg_lower" == *"."* ]] && [ ".${last_arg_lower##*.}" = ".pdf" ]; then
            # shellcheck disable=SC2124
            pdf_name="$last_arg"        # use last argument as pdf name,
            set -- "${@:1:$(($# - 1))}" # Remove the last argument
        fi
    fi

    magick "$@" \
        -background white -density 72 -units PixelsPerInch -page A4 "$pdf_name"
}

image-to-gray-scale() {
    if [ "$#" == 0 ]; then
        echo "Usage: image-to-gray-scale input.jpg [output.jpg]"
        return
    fi

    local img_name
    if [ "$#" -gt 1 ]; then
        img_name="$2"
    else
        img_name="$(basename -- "$1").gs.jpg"
    fi

    magick "$1" -colorspace Gray -separate -evaluate-sequence Mean "$img_name"
}

combine-pdf() {
    if [ "$#" == 0 ]; then
        echo "Usage: combine-pdf input-files [output.pdf]"
        return
    fi

    local output_name
    output_name="output.pdf" # Default name for the output pdf

    if [ "$#" -gt 1 ]; then
        local last_arg
        for f in "$@"; do last_arg="$f"; done

        if [ ! -e "$last_arg" ]; then
            output_name="$last_arg"
            set -- "${@:1:$(($# - 1))}" # Remove the last argument
        fi
    fi

    pdfunite "$@" "$output_name"
}

convert-pdf-to-png() {
    magick -density 300 "$1" "$(_get_basename "$1").png"
}

