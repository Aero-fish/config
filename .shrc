alias dh="dirs -v"

alias diff="diff --color=auto"
alias ip="ip --color=auto"

alias h="history"
alias gh="history | grep"
alias j="jobs -l"

alias c="printf '\e[3J\e[H'"
alias cls="printf '\e[3J\e[H'"
alias q="exit 0"
alias :q="exit 0"

alias wget="wget -c"
alias sha="shasum -a 256"
# shellcheck disable=SC2142
alias mnt="mount | awk -F' ' '{ printf \"%s\t%s\n\",\$1,\$3; }' | column -t | grep -E ^/dev/ | sort" # List all mounts

alias path="echo -e \${PATH//:/\\\\n}"
alias now="date +'%T'"
alias nowtime=now
alias nowdate="date +'%d-%m-%Y'"

